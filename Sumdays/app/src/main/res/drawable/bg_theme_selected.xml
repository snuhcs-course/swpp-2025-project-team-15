<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 배경 (투명 or 살짝 강조) -->
    <solid android:color="@android:color/transparent" />

    <!-- 테두리 -->
    <stroke
        android:width="2dp"
        android:color="@color/theme_default_primary" />

    <!-- 둥근 모서리 -->
    <corners android:radius="12dp"/>

    <!-- 안쪽 여백 (선택 강조 느낌) -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp"/>
</shape>