<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#1F000000">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#f4f4f4"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="1dp"
                android:color="#3f3b3b"/>
            <padding
                android:top="4dp"
                android:left="4dp"
                android:right="4dp"
                android:bottom="4dp"/>
        </shape>
    </item>
</ripple>
