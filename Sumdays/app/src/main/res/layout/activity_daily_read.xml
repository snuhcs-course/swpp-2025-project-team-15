<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".DailyReadActivity">

    <!-- 상단 날짜 / 이전·다음 / 메모 보기 버튼 영역 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/date_text"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="@dimen/text_size_S"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="2025-09-27" />

        <ImageView
            android:id="@+id/prev_day_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back_white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/date_text"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/next_day_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_forward_white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/date_text"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/edit_memos_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/sea_clear_aqua"
            android:minHeight="0dp"
            android:paddingVertical="8dp"
            android:text="메모 보기"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 분석 아이콘 + 키워드 영역 -->
    <LinearLayout
        android:id="@+id/analysis_header_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="64dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="64dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_layout">

        <TextView
            android:id="@+id/comment_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textSize="@dimen/text_size_XXL"
            tools:text="🤔" />

        <TextView
            android:id="@+id/keywords_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textSize="@dimen/text_size_L"
            android:textStyle="bold"
            tools:text="산책, 생각, 사유, 자아성찰" />
    </LinearLayout>

    <!-- 하단 네비게이션 바 -->
    <include
        android:id="@+id/bottom_buttons_layout"
        layout="@layout/include_navigation_bar"
        android:layout_width="0dp"
        android:layout_height="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 감정 상태 여우 아이콘 -->
    <ImageView
        android:id="@+id/fox_face_image"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"
        android:src="@drawable/dailyread_fox_face_level_3"
        app:layout_constraintBottom_toTopOf="@+id/bottom_buttons_layout"
        app:layout_constraintEnd_toEndOf="parent"
        tools:src="@drawable/dailyread_fox_face_level_3" />

    <!-- 사진 갤러리 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/photo_gallery_recycler_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:minHeight="80dp"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="@+id/fox_face_image"
        app:layout_constraintEnd_toStartOf="@+id/fox_face_image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/fox_face_image"
        tools:listitem="@layout/item_photo_gallery" />

    <!-- AI 코멘트 말풍선 -->
    <TextView
        android:id="@+id/comment_text"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="@drawable/dailyread_speechbubble_background"
        android:gravity="top|start"
        android:lineSpacingExtra="4sp"
        android:paddingStart="40dp"
        android:paddingTop="16dp"
        android:paddingEnd="40dp"
        android:paddingBottom="16dp"
        android:textColor="@android:color/black"
        android:textSize="@dimen/text_size_S"
        app:layout_constraintBottom_toTopOf="@+id/fox_face_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="400dp"
        tools:text="산책 속에서 생각이 많았지만 차분한 자아성찰로 마무리된 하루였습니다." />

    <!-- 일기 내용 영역 (보기 / 수정 모드 전환) -->
    <ScrollView
        android:id="@+id/diary_scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toTopOf="@+id/comment_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/analysis_header_layout">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/diary_content_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="8sp"
                android:textSize="@dimen/text_size_S"
                android:visibility="visible"
                tools:text="오늘은 산책하면서 생각이 많았던 하루였다. (일기 내용...)" />

            <EditText
                android:id="@+id/diary_content_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:lineSpacingExtra="8sp"
                android:textColorHint="@color/text_color_hint"
                android:textSize="@dimen/text_size_S"
                android:visibility="gone"
                tools:text="수정 모드..." />
        </FrameLayout>
    </ScrollView>

    <!-- 일기 수정 / 저장 버튼 -->
    <ImageView
        android:id="@+id/edit_inplace_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/memo_background_grey"
        android:elevation="4dp"
        android:padding="12dp"
        android:src="@drawable/ic_edit_white"
        app:layout_constraintBottom_toBottomOf="@+id/diary_scroll_view"
        app:layout_constraintEnd_toEndOf="@+id/diary_scroll_view"
        app:tint="@android:color/black" />

    <ImageView
        android:id="@+id/save_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/memo_background_grey"
        android:elevation="4dp"
        android:padding="12dp"
        android:src="@drawable/ic_check_black"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/diary_scroll_view"
        app:layout_constraintEnd_toEndOf="@+id/diary_scroll_view"
        app:tint="@android:color/black" />

</androidx.constraintlayout.widget.ConstraintLayout>
