<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/setting_main_root"
    android:fitsSystemWindows="true"
    android:background="@color/background"
    tools:context=".CalendarActivity">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_arrow_back_black"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="설정"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="5dp"
            style="@style/TextAppearance.App.Normal" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="50dp"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        tools:layout_editor_absoluteX="-16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/dark_divider" />

            <!-- 세부 설정 페이지 버튼 -->
            <LinearLayout
                android:id="@+id/diaryStyleBlock"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/diaryStyleBlockText"
                    style="@style/TextAppearance.App.Normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="24dp"
                    android:text="일기 스타일 설정" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/notificationBlock"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/notificationBlockText"
                    style="@style/TextAppearance.App.Normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="24dp"
                    android:text="알림 설정" />
            </LinearLayout>

            <!-- 주간통계 수동 추가 (기능 보류, 추후 복구)
            <LinearLayout
                android:id="@+id/summaryBlock"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/summaryBlockText"
                    style="@style/TextAppearance.App.Normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="24dp"
                    android:text="주간통계 수동 추가" />
            </LinearLayout>
            -->

            <LinearLayout
                android:id="@+id/accountBlock"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/accountBlockText"
                    style="@style/TextAppearance.App.Normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="24dp"
                    android:text="계정 설정" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/labsBlock"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/labsBlockText"
                    style="@style/TextAppearance.App.Normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="24dp"
                    android:text="길이 설정" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tutorialBlock"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tutorialBlockText"
                    style="@style/TextAppearance.App.Normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="24dp"
                    android:text="튜토리얼 다시보기" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>