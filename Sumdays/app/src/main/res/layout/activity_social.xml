<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/setting_main_root"
    android:fitsSystemWindows="true"
    android:background="@color/background"
    tools:context=".CalendarActivity">

    <!--
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@android:color/transparent"
        android:contentDescription="back"
        android:src="@drawable/ic_arrow_back_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="Social"
        android:textColor="#222222"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageButton
        android:id="@+id/btnUpdate"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="@android:color/transparent"
        android:contentDescription="refresh"
        android:src="@drawable/ic_update"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAllSocialSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="16dp"
        android:text="친구 리스트"
        android:textColor="#222222"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <TextView
        android:id="@+id/tvSocialRequests"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="23dp"
        android:layout_marginEnd="16dp"
        android:text="친구 요청 3"
        android:textColor="#D17B0F"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <EditText
        android:id="@+id/etSearchSocial"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="2dp"
        android:background="@android:drawable/editbox_background"
        android:hint="친구 검색"
        android:paddingStart="16dp"
        android:paddingEnd="18dp"
        android:textColor="#222222"
        android:textColorHint="#888888"
        app:layout_constraintTop_toBottomOf="@id/tvAllSocialSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnAddSocial" />
    <ImageButton
        android:id="@+id/btnAddSocial"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="6dp"
        android:contentDescription="친구 추가"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_add_people"
        app:layout_constraintBottom_toBottomOf="@id/etSearchSocial"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/etSearchSocial" />





    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSocial"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/etSearchSocial"
        app:layout_constraintBottom_toTopOf="@id/navigation_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="아직 친구가 없습니다."
        android:textSize="16sp"
        android:textColor="#888888"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recyclerSocial"
        app:layout_constraintBottom_toBottomOf="@id/recyclerSocial"
        app:layout_constraintStart_toStartOf="@id/recyclerSocial"
        app:layout_constraintEnd_toEndOf="@id/recyclerSocial" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="데이터를 불러올 수 없습니다."
        android:textSize="16sp"
        android:textColor="#D32F2F"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recyclerSocial"
        app:layout_constraintBottom_toBottomOf="@id/recyclerSocial"
        app:layout_constraintStart_toStartOf="@id/recyclerSocial"
        app:layout_constraintEnd_toEndOf="@id/recyclerSocial" />

    <include
        android:id="@+id/navigation_bar"
        layout="@layout/include_navigation_bar"
        android:layout_width="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>