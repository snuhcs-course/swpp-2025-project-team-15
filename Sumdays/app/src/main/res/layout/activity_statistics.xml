<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/statistics_background_1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/statistics_background_morning"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"/>

    <ImageView
        android:id="@+id/statistics_background_2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/statistics_background_evening"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:alpha="0"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:fastScrollEnabled="true"
        />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="12dp"
        android:background="@drawable/bg_image_drawer_rounded_light_alpha80"
        android:layout_gravity="top"
        android:gravity="center_vertical">

    <!-- 1.1. 뒤로 가기 버튼 -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_back_white"
        android:background="@android:color/transparent"
        android:contentDescription="뒤로 가기"
        android:padding="8dp"/>

    <!-- 1.2. 지표 컨테이너 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginEnd="16dp"

        >

        <!-- A. 스트라이크 (Strike) -->
        <TextView
            android:id="@+id/tv_strike_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 15"
            android:textSize="@dimen/text_size_M"
            android:textColor="@android:color/black"
            android:layout_marginEnd="16dp"/>

        <!-- B. 잎 개수 (Week Summary Count) -->
        <TextView
            android:id="@+id/tv_leaf_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍃 45"
            android:textSize="@dimen/text_size_M"
            android:textColor="@android:color/black"
            android:layout_marginEnd="16dp"/>

        <!-- C. 포도 개수 (Month Summary Count) -->
        <TextView
            android:id="@+id/tv_grape_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍇 3"
            android:textSize="@dimen/text_size_M"
            android:textColor="@android:color/black"/>

    </LinearLayout>
</LinearLayout>

