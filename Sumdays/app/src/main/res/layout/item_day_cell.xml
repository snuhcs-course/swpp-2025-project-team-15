<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="4dp"
    android:paddingBottom="0dp"
    android:backgroundTint="@android:color/transparent"
    >

    <TextView
        android:id="@+id/tv_circle"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="" />

    <TextView
        android:id="@+id/tv_emoji"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:textSize="@dimen/text_size_L"
        android:text="🎉"
        android:visibility="gone"

        app:layout_constraintEnd_toEndOf="@id/tv_circle"
        app:layout_constraintTop_toTopOf="@id/tv_circle"
        app:layout_constraintBottom_toBottomOf="@id/tv_circle"
        app:layout_constraintStart_toStartOf="@id/tv_circle"
        />

    <TextView
        android:id="@+id/tv_day_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="15"
        android:textSize="12sp"
        android:textColor="@color/textColor"
        app:layout_constraintTop_toBottomOf="@id/tv_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>